# ============================================
# WAHA CRM - Variables de Producción
# ============================================
# COPIA este archivo a .env y completa los valores
# NUNCA committees este archivo con valores reales

# --- PostgreSQL ---
POSTGRES_DB=waha_crm
POSTGRES_USER=waha_crm
POSTGRES_PASSWORD=<genera-una-contraseña-segura-min-16-caracteres>

# --- Redis ---
REDIS_PASSWORD=<genera-una-contraseña-segura>

# --- JWT (CRÍTICO - genera una clave larga y única) ---
JWT_SECRET=<genera-al-menos-32-caracteres-aleatorios>
JWT_EXPIRES_IN=8h
AUTH_COOKIE_SECURE=true

# --- WAHA ---
WAHA_API_KEY=<api-key-para-waha>
WAHA_API_KEY_PLAIN=<misma-api-key>
WAHA_WEBHOOK_HMAC_KEY=<hmac-key-para-validar-webhooks>
WAHA_URL=http://waha:3000
WAHA_HOOK_URL=http://backend:3001/api/webhooks/waha
WAHA_HOOK_EVENTS=session.status,message,message.ack
WAHA_SESSION=default

# --- WAHA Dashboard / Swagger ---
WAHA_SWAGGER_USERNAME=<usuario-admin>
WAHA_SWAGGER_PASSWORD=<contraseña-admin>
WAHA_DASHBOARD_USERNAME=<usuario-dashboard>
WAHA_DASHBOARD_PASSWORD=<contraseña-dashboard>

# --- Seed inicial ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=<contraseña-para-el-admin-inicial>

# --- Backend ---
DATABASE_URL=postgresql://waha_crm:<POSTGRES_PASSWORD>@postgres:5432/waha_crm?schema=public
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379
BACKEND_PORT=3001
MAX_MEDIA_DOWNLOAD_BYTES=26214400

# --- Frontend ---
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3001/api
VITE_SOCKET_URL=ws://localhost:3001
FRONTEND_ORIGIN=http://localhost:5173

# --- Feature flags ---
RESYNC_CHAT_LIMIT=10
RESYNC_MESSAGES_PER_CHAT=20
RESYNC_LOOKBACK_MINUTES=1440
MEDIA_STORAGE_PATH=/app/storage/media
OUTBOX_RECOVERY_ON_START=false
