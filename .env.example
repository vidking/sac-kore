COMPOSE_PROJECT_NAME=waha_crm

POSTGRES_DB=waha_crm
POSTGRES_USER=waha_crm
POSTGRES_PASSWORD=waha_crm_password
DATABASE_URL=postgresql://waha_crm:waha_crm_password@postgres:5432/waha_crm?schema=public

REDIS_PASSWORD=change-this-redis-password
REDIS_URL=redis://:change-this-redis-password@redis:6379
REALTIME_REDIS_CHANNEL=crm-realtime-events

BACKEND_PORT=3001
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3001/api
VITE_SOCKET_URL=http://localhost:3001
FRONTEND_ORIGIN=http://localhost:5173

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
AUTH_COOKIE_SECURE=false
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123456

WAHA_URL=http://waha:3000
WAHA_PUBLIC_URL=http://localhost:3000
WAHA_SESSION=default
WAHA_API_KEY_PLAIN=local-waha-secret
WAHA_API_KEY=local-waha-secret
WAHA_WEBHOOK_HMAC_KEY=local-webhook-hmac
WAHA_HOOK_URL=http://backend:3001/api/webhooks/waha
WAHA_HOOK_EVENTS=session.status,message,message.ack

RESYNC_CHAT_LIMIT=10
RESYNC_MESSAGES_PER_CHAT=20
RESYNC_LOOKBACK_MINUTES=1440
MEDIA_STORAGE_PATH=/app/storage/media
MAX_MEDIA_DOWNLOAD_BYTES=26214400
OUTBOX_RECOVERY_ON_START=false
